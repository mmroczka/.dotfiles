              "detect_key_down_uninterruptedly" : true,
              "key_down_order" : "insensitive",
              "key_up_order" : "insensitive",
              "key_up_when" : "any",
              "to_after_key_up" : [ {
                "set_variable" : {
                  "name" : "launch_mode",
                  "value" : 0
                }
              } ]
            }
          },
          "to" : [ {
            "set_variable" : {
              "name" : "launch_mode",
              "value" : 1
            }
