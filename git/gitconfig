[core]
	excludesfile = /Users/mmroczka/.gitignore_global
 [alias]
    upstream = ![[ $(git config "branch.$(git symbolic-ref --short HEAD).merge") = '' ]] && git push -u origin $(git symbolic-ref --short HEAD) || git push
[commit]
	gpgsign = true
[push]
	gpgsign = if-asked
[gpg]
	program = /usr/local/bin/gpg

# Below is used because terminal prompts happen after running a 'make all'
# it’s because the git is trying to authenticate with HTTPS even though you already setup SSH
# The following commands force it to use SSH


[url "git://git.soma.salesforce.com/"]
[url "ssh://git.soma.salesforce.com/"]
[url "git@git.soma.salesforce.com:"]
